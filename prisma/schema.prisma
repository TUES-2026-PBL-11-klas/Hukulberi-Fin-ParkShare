generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  DRIVER
  HOST
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum PaymentProviderType {
  STRIPE
}

enum PaymentStatus {
  CREATED
  SUCCEEDED
  FAILED
  CANCELED
}

enum BookingStatus {
  HOLD
  CONFIRMED
  CANCELED
  EXPIRED
}

enum ReviewRating {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

enum AccessEventStatus {
  SUCCESS
  FAILED
  DENIED
}

enum WebhookProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(320)
  name         String     @db.VarChar(120)
  passwordHash String     @map("password_hash") @db.Text
  role         UserRole   @default(DRIVER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  payments     Payment[]
  bookings     Booking[]
  spots        Spot[]          // Spots hosted by this user
  reviews      Review[]        // Reviews written by this user
  accessEvents AccessEvent[]   // Access events triggered by this user

  @@map("users")
}

model Payment {
  id                        String              @id @default(uuid()) @db.Uuid
  bookingId                 String?             @map("booking_id") @db.Uuid
  driverUserId              String              @map("driver_user_id") @db.Uuid
  provider                  PaymentProviderType @default(STRIPE)
  status                    PaymentStatus       @default(CREATED)
  providerCheckoutSessionId String?             @unique @map("provider_checkout_session_id") @db.VarChar(255)
  providerPaymentIntentId   String?             @map("provider_payment_intent_id") @db.VarChar(255)
  amount                    Int
  currency                  String              @db.Char(3)
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  driverUser User                 @relation(fields: [driverUserId], references: [id], onDelete: Restrict)
  booking    Booking?             @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  webhooks   PaymentWebhookEvent[]

  @@index([driverUserId])
  @@index([bookingId])
  @@map("payments")
}

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  spotId       String        @map("spot_id") @db.Uuid
  spotLabel    String        @map("spot_label") @db.VarChar(160)
  driverUserId String        @map("driver_user_id") @db.Uuid
  status       BookingStatus @default(HOLD)
  amount       Int
  currency     String        @db.Char(3)
  startAt      DateTime      @map("start_at") @db.Timestamptz(6)
  endAt        DateTime      @map("end_at") @db.Timestamptz(6)
  expiresAt    DateTime      @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  driverUser User      @relation(fields: [driverUserId], references: [id], onDelete: Restrict)
  spot       Spot      @relation(fields: [spotId], references: [id], onDelete: Restrict)
  payments   Payment[]
  review     Review?        // One review per booking (optional, created after completed)

  @@index([driverUserId])
  @@index([spotId])
  @@index([status])
  @@index([startAt, endAt])
  @@map("bookings")
}

model PaymentWebhookEvent {
  id               String                  @id @default(uuid()) @db.Uuid
  provider         PaymentProviderType     @default(STRIPE)
  providerEventId  String                  @unique @map("provider_event_id") @db.VarChar(255)
  paymentId        String?                 @map("payment_id") @db.Uuid
  eventType        String                  @map("event_type") @db.VarChar(120)
  processingStatus WebhookProcessingStatus @map("processing_status")
  rawJson          Json                    @map("raw_json")
  receivedAt       DateTime                @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt      DateTime?               @map("processed_at") @db.Timestamptz(6)

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@map("payment_webhook_events")
}

model Spot {
  id          String   @id @default(uuid()) @db.Uuid
  hostUserId  String   @map("host_user_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  address     String   @db.VarChar(500)
  latitude    Float    @db.Real
  longitude   Float    @db.Real
  pricePerHour Int    // Price in cents (e.g., 1500 = $15.00)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  hostUser User      @relation(fields: [hostUserId], references: [id], onDelete: Restrict)
  bookings Booking[]
  reviews  Review[]

  @@index([hostUserId])
  @@index([isActive])
  @@index([latitude, longitude])  // For geospatial queries
  @@map("spots")
}

model Review {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @unique @map("booking_id") @db.Uuid  // One review per booking
  authorId  String        @map("author_id") @db.Uuid           // Driver who completed booking
  spotId    String        @map("spot_id") @db.Uuid             // Which spot they're reviewing
  rating    ReviewRating
  comment   String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Restrict)
  spot    Spot    @relation(fields: [spotId], references: [id], onDelete: Restrict)

  @@index([spotId])
  @@index([authorId])
  @@map("reviews")
}

model AccessEvent {
  id        String              @id @default(uuid()) @db.Uuid
  bookingId String              @map("booking_id") @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  gateId    String              @map("gate_id") @db.VarChar(100)
  status    AccessEventStatus
  reason    String?             @db.VarChar(255)  // Reason for failure/denial
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([userId])
  @@index([gateId])
  @@map("access_events")
}
